{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "noEmit": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/main/**/*.ts", "src/main/**/*.d.ts", "src/shared/**/*.ts", "src/shared/**/*.d.ts"]
}
