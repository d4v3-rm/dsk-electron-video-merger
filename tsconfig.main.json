{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "noEmit": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": [
    "src/main/main.ts",
    "src/main/preload.ts",
    "src/main/ipc/**/*.ts",
    "src/main/services/**/*.ts",
    "src/main/config/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
