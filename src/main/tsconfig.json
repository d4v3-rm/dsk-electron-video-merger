{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "../../dist",
    "rootDir": "../",
    "types": ["node"],
    "noEmit": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["main.ts", "preload.ts", "ipc/**/*.ts", "services/**/*.ts", "../shared/**/*.ts"]
}
