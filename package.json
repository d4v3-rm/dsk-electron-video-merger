{
  "name": "video-merger-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop app for bulk video merging and conversion using Electron + Vite + React",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -k -n RENDERER,MAIN -c cyan,magenta \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "dev:main": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 wait-on tcp:127.0.0.1:5173 && npm run build:main && cross-env NODE_ENV=development node ./scripts/run-electron.cjs",
    "build": "npm run build:main && npm run build:renderer && electron-builder --config electron-builder.config.cjs",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "build:portable": "npm run build",
    "start": "node ./scripts/run-electron.cjs",
    "typecheck": "tsc -p src/main/tsconfig.json && tsc -p src/renderer/tsconfig.app.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "antd": "^5.25.0",
    "ffmpeg-static": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.4",
    "vite": "^7.3.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.videomerger.desktop",
    "productName": "VideoMerger",
    "directories": {
      "output": "dist/packaged",
      "buildResources": "build"
    },
    "files": ["dist/main/**/*", "dist/shared/**/*", "dist/renderer/**/*", "package.json"],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "VideoMerger-${version}-portable.exe"
    }
  }
}

