{
  "name": "dsk-electron-video-merger",
  "private": true,
  "version": "1.0.0",
  "author": "Video Merger Desktop",
  "description": "Desktop video merging and conversion app built with Electron, Vite, React, and TypeScript",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -k -n RENDERER,MAIN -c cyan,magenta \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "node ./scripts/dev-main.cjs",
    "build": "npm run build:main && npm run build:renderer && electron-builder --config electron-builder.config.cjs",
    "build:main": "tsc -p tsconfig.main.json && tsc-alias -p tsconfig.main.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build:portable": "npm run build",
    "generate:icon": "node ./scripts/generate-app-icon.mjs",
    "start": "node ./scripts/run-electron.cjs",
    "typecheck": "tsc -p tsconfig.shared.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.cjs,.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,cjs,mjs,css,html,json}\" \"scripts/**/*.{js,cjs,mjs}\" \"*.{json,cjs,md}\"",
    "set:version": "node ./scripts/set-version.mjs"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "antd": "^5.25.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "gsap": "^3.14.2",
    "i18next": "^25.8.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.3",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.4",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^8.0.5"
  }
}
